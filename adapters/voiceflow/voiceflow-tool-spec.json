{
  "name": "build_wa3_draft",
  "description": "Send guided answers to a trusted WA3 builder backend and return build/trust status.",
  "input_schema": {
    "type": "object",
    "required": ["answers"],
    "properties": {
      "answers": {
        "type": "object",
        "description": "WA3 builder answers matching builder/answers.schema.json."
      }
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["ok"],
    "properties": {
      "ok": {"type": "boolean"},
      "state": {"type": "string"},
      "error_code": {"type": "string"},
      "repair_hint": {"type": "string"}
    }
  }
}
